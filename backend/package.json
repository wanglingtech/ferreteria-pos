{
  "name": "ferreteria-july-backend",
  "version": "1.0.0",
  "description": "Backend API for Ferreteria July",
  "main": "src/server.js",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "prisma:generate": "prisma generate --schema src/prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema src/prisma/schema.prisma",
    "prisma:deploy": "prisma migrate deploy --schema src/prisma/schema.prisma",
    "db:seed": "node src/prisma/seed.js",
    "test": "node -e \"console.log('No tests configured yet')\""
  },
  "keywords": [
    "ferreteria",
    "express",
    "prisma",
    "postgresql"
  ],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@prisma/client": "^6.8.2",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "nodemon": "^3.1.14",
    "prisma": "^6.8.2"
  },
  "prisma": {
    "seed": "node src/prisma/seed.js"
  }
}
